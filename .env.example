# Copy this file to ".env" and fill in your token.
# Get a free public token at https://account.mapbox.com/access-tokens/

VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Yelp Fusion API — free key at https://www.yelp.com/developers/v3/manage_app
# Only needed to run the one-time seeder script. Not exposed to the browser.
YELP_API_KEY=your_yelp_api_key_here
