# Copy this file to ".env" and fill in your keys. Never commit .env.

# Runtime: Mapbox map in the browser.
# Get a free public token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Runtime: Vercel email endpoints for cafe submissions and closure reports.
RESEND_API_KEY=your_resend_api_key_here
RESEND_TO_EMAIL=you@example.com
RESEND_FROM_EMAIL=Melbourne Cafe Finder <hello@yourdomain.com>

# Maintenance scripts only. These are never exposed to the browser.
GEOAPIFY_KEY=your_geoapify_api_key_here
GOOGLE_PLACES_KEY=your_google_places_api_key_here
SERPER_KEY=your_serper_api_key_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional maintenance-script limits.
PLACES_LIMIT=0
PHOTO_LIMIT=0
PHOTO_ALL=
