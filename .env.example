# Copy this file to ".env" and fill in your keys. Never commit .env.

# Mapbox — get a free public token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Geoapify Places API — https://myprojects.geoapify.com
# Free tier: 3,000 requests/day. Used by scripts/scrape_geoapify.js (run once, not in browser).
GEOAPIFY_KEY=your_geoapify_api_key_here
